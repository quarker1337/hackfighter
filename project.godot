; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via script.

[application]

config/name="Stoat Fighter 2"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6")

[display]

window/size/viewport_width=512
window/size/viewport_height=288
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/vsync/vsync_mode=0

[autoload]

SoundManager="*res://scripts/sound_manager.gd"

[rendering]

textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
environment/defaults/default_clear_color=Color(0.051, 0.122, 0.235, 1)

